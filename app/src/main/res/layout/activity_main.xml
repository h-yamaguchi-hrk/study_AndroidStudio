<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="デバッグ練習用アプリ"
        android:textSize="24sp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnProblem1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="問題1：計算バグ（確認用）"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnProblem2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="問題2：ループ処理バグ（確認用）"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnProblem3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="問題3：強制終了バグ（確認用）"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ここに結果が表示されます"
        android:textSize="18sp"
        android:textColor="#333333"
        android:layout_marginTop="24dp"
        android:gravity="center"/>

</LinearLayout>
